# App
NODE_ENV=development
PORT=3002
CLIENT_URL=http://localhost:3000

# MySQL (via Prisma)
DATABASE_URL="mysql://root:rootpassword@localhost:3306/gameplatform_users"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — must match auth-service for token verification
JWT_ACCESS_SECRET=your-super-secret-access-key-min-32-chars

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
